function AimLock()
	local mousePos = game.UserInputService:GetMouseLocation()
	local lastmagnitude = math.huge --just for the start

	local c_plr
	local c_npc

	if foundPlace and child_table then
		if child_table.plr_folder and child_table.npc_folder then
			c_plr = child_table.plr_folder:GetChildren()
			c_npc = child_table.npc_folder:GetChildren()
		elseif child_table.npc_folder and not child_table.plr_folder then
			c_plr = child_table.npc_folder:GetDescendants()
			c_npc = child_table.npc_folder:GetChildren()
		elseif child_table.plr_folder and not child_table.npc_folder then	
			c_plr = child_table.plr_folder:GetChildren()
			c_npc = child_table.plr_folder:GetDescendants()
		end
	else
		c_plr = child_table.plr_folder:GetDescendants()
		c_npc = child_table.npc_folder:GetDescendants()
	end

	local function finding_(children)
		for i,v in pairs(children) do
			if v:IsA("Model") and v:FindFirstChild("Humanoid") then
				if v == plr.Character then continue end
				
				local enemy = v
				if enemy:FindFirstChild("HumanoidRootPart") then
					local enemypos = enemy[targetpart].CFrame.Position
					local playerpos = plr.Character.PrimaryPart.CFrame.Position

					local screenPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(enemypos)

					if onScreen then
						local dist = (Vector2.new(mousePos.X, mousePos.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
						if dist <= detectionRadius then
							
							if not detect_through_wall then
								local ray_param = RaycastParams.new()
								ray_param.FilterType = Enum.RaycastFilterType.Exclude
								ray_param.FilterDescendantsInstances = {plr.Character, enemy}
								local raycast = workspace:Raycast(playerpos, enemypos, ray_param)
								if raycast then continue end
							end
							
							local enemyplr = game.Players:GetPlayerFromCharacter(enemy)
							if enemyplr and lockplayer then
								if not lockteam and enemyplr.Team == plr.Team then continue end
								if table.find(ignore_players, enemyplr.Name) then continue end
								targetenemy = enemy
								return
							elseif not enemyplr and locknpc then
								targetenemy = enemy
								return
							end
						end
					end
				end
			end
		end
	end

	if locknpc then
		finding_(c_npc)
	end

	if lockplayer then
		finding_(c_plr)
	end

end

