	end)
end

local function remove_plr_b(p)
	local partbutton = ignore_players_scrollframe:FindFirstChild(p.Name)
	if partbutton then
		partbutton:Destroy()
	end
end

for _,p in pairs(players:GetPlayers()) do
	if table.find(ignore_players, p.Name) then return end
	create_plr_b(p)
end

players.PlayerAdded:Connect(function(player)
	if table.find(ignore_players, player.Name) then return end
	create_plr_b(player)
end)

players.PlayerRemoving:Connect(function(player)
	if table.find(ignore_players, player.Name) then
		table.remove(ignore_players, table.find(ignore_players, player.Name))
	end
	remove_plr_b(player)
end)

