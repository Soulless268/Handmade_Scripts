	task.spawn(function()
		local x,y = getMousePosition()
		radius.Position = UDim2.new(0, x, 0, y) - UDim2.new(
			radius.Size.X.Scale / 2, radius.Size.X.Offset / 2,
			radius.Size.Y.Scale / 2, radius.Size.Y.Offset / 2
		)
	end)

	if enable and targetenemy == nil then
		AimLock()
	end
end)

