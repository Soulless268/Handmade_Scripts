	end

	if not targetenemy 
		or not (targetenemy:IsDescendantOf(child_table.plr_folder) or not targetenemy:IsDescendantOf(child_table.npc_folder))
		or (targetenemy.Humanoid:GetState() == Enum.HumanoidStateType.Dead and not lock_after_dead) then
		targetenemy = nil
	end
end)

