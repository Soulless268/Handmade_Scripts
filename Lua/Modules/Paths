function missing(t, f, fallback)
	if type(f) == t then return f end
	return fallback
end

function safeFind(root, ...)
	local current = root
	for _, name in ipairs({...}) do
		if not current then return nil end
		current = current:FindFirstChild(name)
	end
	return current
end

