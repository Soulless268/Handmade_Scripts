local function sampleTrajectory(part, totalTime, dt)
	local samples = {}
	if dt <= 0 then return samples end
	local steps = math.floor(totalTime / dt)
	local pos0 = part.Position
	local v0 = part.AssemblyLinearVelocity
	local g = Vector3.new(0, -workspace.Gravity, 0)

	for i = 1, steps do
		local t = i * dt
		local pos = pos0 + v0 * t + 0.5 * g * t * t
		table.insert(samples, pos)
	end
	return samples
end

local function drawTrajectory(part)
	-- Example usage:
	-- local points = sampleTrajectory(somePart, 2, 0.05) -- positions for 0->2s every 0.05s
	local points = sampleTrajectory(part, totalTime_prediction, dt_prediction)
	-- remove old markers (simple approach)
	for _, p in ipairs(workspace:GetChildren()) do
		if p.Name == "TrajMarker" then p:Destroy() end
	end
	for i, pos in ipairs(points) do
		local m = Instance.new("Part")
		m.Size = Vector3.new(0.2,0.2,0.2)
		m.Anchored = true
		m.CanCollide = false
		m.Position = pos
		m.Name = "TrajMarker"
		m.Parent = workspace
	end
end

