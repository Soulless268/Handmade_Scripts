local function get_child_folder(name)
	if not child_table[name] then return end
	local folder = child_table[name].path :: Folder
	local found = child_table[name].found :: boolean
	local children
	if not folder then return end
	if folder ~= workspace and found then
		children = folder:GetChildren()
	elseif folder == workspace and not found then
		children = folder:GetDescendants()
	elseif folder == workspace and found then
		children = folder:GetChildren()
	end
	return children
end

local function sampleTrajectory(part, totalTime, dt)
	local samples = {}
	if dt <= 0 then return samples end
	local steps = math.floor(totalTime / dt)
	local pos0 = part.Position
	local v0 = part.AssemblyLinearVelocity
	local g = Vector3.new(0, -workspace.Gravity, 0)

	for i = 1, steps do
		local t = i * dt
		local pos = pos0 + v0 * t + 0.5 * g * t * t
		table.insert(samples, pos)
	end
	return samples
end

local function drawTrajectory(part)
	-- Example usage:
	-- local points = sampleTrajectory(somePart, 2, 0.05) -- positions for 0->2s every 0.05s
	local points = sampleTrajectory(part, totalTime_prediction, dt_prediction)
	-- remove old markers (simple approach)
	for _, p in ipairs(workspace:GetChildren()) do
		if p.Name == "TrajMarker" then p:Destroy() end
	end
	for i, pos in ipairs(points) do
		local m = Instance.new("Part")
		m.Size = Vector3.new(0.2,0.2,0.2)
		m.Anchored = true
		m.CanCollide = false
		m.Position = pos
		m.Name = "TrajMarker"
		m.Parent = workspace
	end
end

local function finding_(mousePos, children)
	for i,v in pairs(children) do
		if v:IsA("Model") and v:FindFirstChild("Humanoid") then
			if v == plr.Character then continue end

			local enemy = v
			if enemy:FindFirstChild("HumanoidRootPart") then
				local enemypos = enemy[targetpart].CFrame.Position
				local playerpos = plr.Character.PrimaryPart.CFrame.Position

				local screenPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(enemypos)

				if onScreen then
					local dist = (Vector2.new(mousePos.X, mousePos.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
					if dist <= detectionRadius then

						if not detect_through_wall then
							local ray_param = RaycastParams.new()
							ray_param.FilterType = Enum.RaycastFilterType.Exclude
							ray_param.FilterDescendantsInstances = {plr.Character, enemy}
							local raycast = workspace:Raycast(playerpos, enemypos, ray_param)
							if raycast then continue end
						end

						local enemyplr = game.Players:GetPlayerFromCharacter(enemy)
						if enemyplr and lockplayer then
							if not lockteam and enemyplr.Team == plr.Team then continue end
							if table.find(ignore_players, enemyplr.Name) then continue end
							targetenemy = enemy
							return
						elseif not enemyplr and locknpc then
							targetenemy = enemy
							return
						end
					end
				end
			end
		end
	end
end

function lockon()
	local enemypos = targetenemy[targetpart].CFrame.Position
	local hum = targetenemy.Humanoid :: Humanoid
	local pos = cam.CFrame.Position
	
	if predict_movement and hum then
		local vel = targetenemy[targetpart].AssemblyLinearVelocity
		local predict_pos = enemypos + vel * dt_prediction
		cam.CFrame = CFrame.new(pos, predict_pos)
	else
		cam.CFrame = CFrame.new(pos, enemypos)
	end
end

function AimLock()
	local mousePos = game.UserInputService:GetMouseLocation()
	local lastmagnitude = math.huge --just for the start

	local c_plr = get_child_folder("plr_folder")
	local c_npc = get_child_folder("npc_folder")

	if locknpc then
		finding_(mousePos, c_npc)
	end

	if lockplayer then
		finding_(mousePos, c_plr)
	end

end

local function getMousePosition()
	local mouse = plr_mouse
	local x, y = mouse.X, mouse.Y
	return x, y
end

