	frame.Parent = parent

	local text_label = Instance.new("TextLabel")
	text_label.Text = description
	text_label.BackgroundTransparency = 1
	text_label.RichText = true
	text_label.TextScaled = true
	text_label.Size = UDim2.new(.75,0,1,0)
	text_label.Parent = frame

	local e

	if typeof(value) == "boolean" then
		e = Instance.new("TextButton")
		e.Text = "  "
		e.BackgroundColor3 = if value then truecolor else falsecolor
	elseif typeof(value) == "number" then
		e = Instance.new("TextBox")
		e.Text = tostring(value)
	end

	e.Position = UDim2.new(.75,0,0,0)
	e.Size = UDim2.new(.25,0,1,0)
	e.Parent = frame
end

