local function create_plr_b(p)
	local partbutton = Instance.new("TextButton")
	partbutton.Text = p.Name
	partbutton.BackgroundColor3 = falsecolor
	partbutton.Parent = ignore_players_scrollframe
	partbutton.Activated:Connect(function()
		if table.find(ignore_players, p.Name) then
			table.remove(ignore_players, table.find(ignore_players, p.Name))
			partbutton.BackgroundColor3 = falsecolor
			return
		else
			table.insert(ignore_players, p.Name)
			partbutton.BackgroundColor3 = truecolor
		end
	end)
end

local function remove_plr_b(p)
	local partbutton = ignore_players_scrollframe:FindFirstChild(p.Name)
	if partbutton then
		partbutton:Destroy()
	end
end

