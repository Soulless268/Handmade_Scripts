tp_select_item_button.Activated:Connect(function()
	play_click_button()
	local function bring(v: Instance)
		if v:IsA("Tool") then
			if v:FindFirstChild("Handle") then
				v.Handle.CFrame = CFrame.new(plr.Character.HumanoidRootPart.Position)
			end
		elseif v:IsA("Model") then
			v:PivotTo(CFrame.new(plr.Character.HumanoidRootPart.Position))
		elseif v:IsA("BasePart") then
			v.CFrame = CFrame.new(plr.Character.HumanoidRootPart.Position)
		end
	end

	task.spawn(function()
		if Selected_Item then
			bring(Selected_Item)
		end
	end)
end)

tp_to_select_item_button.Activated:Connect(function()
	play_click_button()
	local function tpto(v: Instance)
		local part 
		if v:IsA("Tool") then
			if v:FindFirstChild("Handle") then
				part = v.Handle
			end
		elseif v:IsA("Model") then
			part = v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")
		elseif v:IsA("BasePart") then
			part = v
		end

		plr.Character.HumanoidRootPart.CFrame = CFrame.new(part.Position)
	end

	task.spawn(function()
		if Selected_Item then
			tpto(Selected_Item)
		end
	end)
end)

spectate_items_button.MouseButton1Down:Connect(function()
	local camera = workspace.CurrentCamera
	task.spawn(function()
		if Selected_Item then
			if Spectate == false then
				if Selected_Item.ClassName == "Tool" then
					camera.CameraSubject = Selected_Item.Handle
				elseif Selected_Item.ClassName == "Part" 
					or Selected_Item.ClassName == "MeshPart" 
					or Selected_Item.ClassName == "Model" then
					camera.CameraSubject = Selected_Item
				end
				Spectate = true
			else
				camera.CameraSubject = game.Players.LocalPlayer.Character.Humanoid
				Spectate = false
			end
		else
			camera.CameraSubject = game.Players.LocalPlayer.Character.Humanoid
			Spectate = false
		end
	end)
end)

