local function deep_find_whitelist(decen)
	for _,v in pairs(decen:GetChildren()) do

		check_valid_obj(v, function()
			local name = v.Name
			local prefix = prefix_name(name)
			if white_list_frame and white_list_frame:FindFirstChildOfClass("ScrollingFrame") and prefix then
				if not white_list_frame:FindFirstChildOfClass("ScrollingFrame"):FindFirstChild(prefix) then
					local button = Instance.new("TextButton")
					button.Text = prefix
					button.Name = prefix
					button.TextScaled = true
					button.Parent = white_list_frame:FindFirstChildOfClass("ScrollingFrame")

					button.Activated:Connect(function()
						play_click_button()
						if table.find(white_list, prefix) then
							table.remove(white_list, table.find(white_list, prefix))
							button.BackgroundColor3 = falsecolor
						else
							table.insert(white_list, prefix)
							button.BackgroundColor3 = truecolor
						end
					end)
				end
			end
		end)

		if v:IsA("Folder") then
			deep_find_whitelist(v)
		end
	end
end

local function deep_find_blacklist(decen)
	for _,v in pairs(decen:GetChildren()) do

		check_valid_obj(v, function()
			local name = v.Name
			local prefix = prefix_name(name)
			if black_list_frame and black_list_frame:FindFirstChildOfClass("ScrollingFrame") and prefix then
				if black_list_frame and not black_list_frame:FindFirstChildOfClass("ScrollingFrame"):FindFirstChild(prefix) then
					local button = Instance.new("TextButton")
					button.Text = prefix
					button.Name = prefix
					button.TextScaled = true
					button.Parent = black_list_frame:FindFirstChildOfClass("ScrollingFrame")

					button.Activated:Connect(function()
						play_click_button()
						if table.find(black_list, prefix) then
							table.remove(black_list, table.find(black_list, prefix))
							button.BackgroundColor3 = falsecolor
						else
							table.insert(black_list, prefix)
							button.BackgroundColor3 = truecolor
						end
					end)
				end
			end
		end)

		if v:IsA("Folder") then
			deep_find_blacklist(v)
		end
	end
end

