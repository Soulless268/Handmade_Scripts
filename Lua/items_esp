local function prefix_name(name)
	--local prefix = string.match(name, "^(%a+)")
	local prefix = string.match(name, "^([^%d#]+)")

	return prefix
end

local function check_valid_obj(obj: Instance, func_)
	if obj:IsA("BasePart") then
		func_()
	elseif obj:IsA("UnionOperation") then
		func_()
	elseif obj:IsA("MeshPart") then
		func_()
	elseif obj:IsA("Part") then
		func_()
	elseif obj:IsA("Tool")
		and not obj.Parent:FindFirstChildOfClass("Humanoid")
		and (obj:FindFirstChild("Handle")
			or obj:FindFirstChildOfClass("BasePart")
			or obj:FindFirstChildOfClass("UnionOperation")
			or obj:FindFirstChildOfClass("MeshPart"))  then
		func_()
	elseif obj:IsA("Model") and not obj:FindFirstChildOfClass("Humanoid") and not obj.Parent:FindFirstChildOfClass("Humanoid") then
		func_()
	end
end

local function addbillboard(part: Instance, text)
	if part:FindFirstChild("BillboardGui") then return end
	local a = Instance.new("BillboardGui")
	a.Parent = part
	a.AlwaysOnTop = true
	a.Size = UDim2.new(0,50,0,50)
	local aa = Instance.new("TextBox")
	UiCorner(aa, UDim.new(0,10))
	aa.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	aa.BackgroundTransparency = 0.5
	aa.TextColor3 = Color3.fromRGB(255, 255, 255)
	aa.Text = text
	aa.Size = UDim2.new(1,0,1,0)
	aa.Parent = a

	local stud = Instance.new("TextLabel")
	stud.Parent = aa
	stud.Size = UDim2.new(1, 0, 0.1, 0)
	stud.BackgroundTransparency = 1
	stud.TextSize = 20
	stud.TextColor3 = Color3.fromRGB(255, 255, 255)

	task.spawn(function()
		local p = part

		if part:IsA("Part") then
			p = part
		elseif part:IsA("Tool") then
			p = part:FindFirstChild("Handle") or part:FindFirstChildOfClass("BasePart") or part:FindFirstChildOfClass("Part")
		elseif part:IsA("Model") then
			p = part.PrimaryPart or part:FindFirstChildOfClass("BasePart")
		else
			p = part
		end

		if aa:IsDescendantOf(workspace) and p.Position then
			if (plr.Character.HumanoidRootPart.Position - p.Position).Magnitude then
				stud.Text =  tostring(math.floor((plr.Character.HumanoidRootPart.Position - p.Position).Magnitude))
			end
		end

		runners_bil[part] = plr.Character:FindFirstChildOfClass("Humanoid").Changed:Connect(function(prop)
			if aa:IsDescendantOf(workspace) and p.Position then
				if (plr.Character.HumanoidRootPart.Position - p.Position).Magnitude then
					stud.Text =  tostring(math.floor((plr.Character.HumanoidRootPart.Position - p.Position).Magnitude))
				end
			else
				runners_bil[part]:Disconnect()
				return
			end
		end)
	end)

	return a
end

local function additem(v: Instance)
	local name = v.Name
	local prefix = prefix_name(name)

	if table.find(black_list, prefix) then return end
	if whitelist_on and not table.find(white_list, prefix) then return end
	if table.find(items_list, v) then return end

	table.insert(items_list, v)
	local bil = addbillboard(v, v.Name)
	if bil ~= nil then
		Bil_List[v] = bil
	end
end

local function add_item_list_buttons()
	for _,f in pairs(items_list) do
		if items_buttons_list[f] then continue end

		local button = Instance.new("TextButton")
		button.Text = f.Name
		button.Name = f.Name
		button.TextScaled = true
		button.Parent = items_select_frame:FindFirstChildOfClass("ScrollingFrame")
		button:SetAttribute("Type", f.ClassName)

		items_buttons_list[f] = button

		button.Activated:Connect(function()
			play_click_button()
			if Selected_button then
				Selected_button.BackgroundColor3 = falsecolor
			end

			Selected_button = button
			Selected_button.BackgroundColor3 = truecolor

			select_items_button.Text = button.Text
			Selected_Item = f
		end)
	end
end

local function add_runner_add_decentdant()
	local runner = workspace.DescendantAdded:Connect(function(child)
		local name = child.Name
		local prefix = prefix_name(name)

		check_valid_obj(child, function()
			if white_list_frame and white_list_frame:FindFirstChildOfClass("ScrollingFrame") and prefix then
				if not white_list_frame:FindFirstChildOfClass("ScrollingFrame"):FindFirstChild(prefix) then
					local button = Instance.new("TextButton")
					button.Text = prefix
					button.Name = prefix
					button.TextScaled = true
					button.Parent = white_list_frame:FindFirstChildOfClass("ScrollingFrame")

					button.Activated:Connect(function()
						play_click_button()
						if table.find(white_list, prefix) then
							table.remove(white_list, table.find(white_list, prefix))
							button.BackgroundColor3 = falsecolor
						else
							table.insert(white_list, prefix)
							button.BackgroundColor3 = truecolor
						end
					end)
				end
			end

			if black_list_frame and black_list_frame:FindFirstChildOfClass("ScrollingFrame") and prefix then
				if black_list_frame and not black_list_frame:FindFirstChildOfClass("ScrollingFrame"):FindFirstChild(prefix) then
					local button = Instance.new("TextButton")
					button.Text = prefix
					button.Name = prefix
					button.TextScaled = true
					button.Parent = black_list_frame:FindFirstChildOfClass("ScrollingFrame")

					button.Activated:Connect(function()
						play_click_button()
						if table.find(black_list, prefix) then
							table.remove(black_list, table.find(black_list, prefix))
							button.BackgroundColor3 = falsecolor
						else
							table.insert(black_list, prefix)
							button.BackgroundColor3 = truecolor
						end
					end)
				end
			end
		end)

		if not EspActive then return end

		if table.find(black_list, prefix) then return end

		check_valid_obj(child, function()
			if table.find(items_list, child) then return end

			if table.find(white_list, prefix) then
				additem(child)
				return
			end
			additem(child)
		end)

		add_item_list_buttons()
	end)
	return runner
end

local function add_runner_remove_decendant()
