local function create_frame(parent, title: string, description: string, value: any, extra_value: any)
	local frame = Instance.new("Frame")
	frame.BackgroundColor3 = Color3.fromRGB(75, 75, 75)
	frame.Parent = parent
	UiStroke(frame)

	local title_label = Instance.new("TextLabel")
	title_label.Text = title
	title_label.TextColor3 = Color3.fromRGB(255, 255, 255)
	title_label.TextStrokeTransparency = 0
	title_label.TextXAlignment = Enum.TextXAlignment.Left
	title_label.BackgroundTransparency = 1
	title_label.RichText = true
	title_label.TextScaled = true
	title_label.Position = UDim2.new(0,0,0,0)
	title_label.Size = UDim2.new(.75,0,.6,0)
	title_label.Parent = frame

	local description_label

	if description then
		description_label = Instance.new("TextLabel")
		description_label.Text = description
		description_label.TextColor3 = Color3.fromRGB(200, 200, 200)
		description_label.TextXAlignment = Enum.TextXAlignment.Left
		description_label.BackgroundTransparency = 1
		description_label.RichText = true
		description_label.TextScaled = true
		description_label.Position = UDim2.new(0,0,.6,0)
		description_label.Size = UDim2.new(.75,0,.4,0)
		description_label.Parent = frame
	end

	local function make_value(value)
		local button
		if value == nil then return end

		if typeof(value) == "boolean" then
			button = Instance.new("TextButton")
			button.Text = "  "
			button.BackgroundColor3 = if value then truecolor else falsecolor
		elseif typeof(value) == "number" then
			button = Instance.new("TextBox")
			button.Text = tostring(value)
		end

		if value == "Click" then
			button = Instance.new("TextButton")
			button.Text = ">"
			button.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
			button.TextScaled = true
		elseif value == "Select" then
			button = Instance.new("TextButton")
			button.Text = "None"
			button.TextScaled = true
			button.TextWrapped = true
		end

		return button
	end

	local e1 = make_value(value)
	local e2 = make_value(extra_value)

	if e2 then
		title_label.Size = UDim2.new(.5,0,.6,0)
		if description_label then
			description_label.Size = UDim2.new(.5,0,.4,0)
		end

		e1.Position = UDim2.new(.75,0,0,0)
		e1.Size = UDim2.new(.25,0,1,0)
		e1.Parent = frame

		e2.Position = UDim2.new(.5,0,0,0)
		e2.Size = UDim2.new(.25,0,1,0)
		e2.Parent = frame
		return e1, e2
	else
		title_label.Size = UDim2.new(.75,0,.6,0)

		if description_label then
			description_label.Size = UDim2.new(.75,0,.4,0)
		end

		e1.Position = UDim2.new(.75,0,0,0)
		e1.Size = UDim2.new(.25,0,1,0)
		e1.Parent = frame
		return e1
	end
end

local function create_dex_instance(parent, obj: Instance, obj_index : number)
	if obj:IsDescendantOf(dex_frame) then return end
	buildCount += 1
	print("create_dex_instance")
	if buildCount % BUILD_BATCH == 0 then
		task.wait() -- yield so Roblox doesn’t timeout
	end
	
	local index = instance_icons[obj.ClassName] or instance_icons.Model

	local frame = Instance.new("Frame")
	frame.BackgroundTransparency = 1
	frame.Name = obj.Name
	frame.LayoutOrder = obj_index
	frame.Size = UDim2.new(1,0,.05,0)
	frame.Parent = parent
	
	local child_frame

	local text_label = Instance.new("TextLabel")
	text_label.Text = obj.Name
	text_label.BackgroundTransparency = 1
	text_label.TextColor3 = Color3.fromRGB(255, 255, 255)
	text_label.TextScaled = true
	text_label.Size = UDim2.new(.8,0,1,0)
	text_label.Position = UDim2.new(.2,0,0,0)
	text_label.TextStrokeTransparency = 0
	text_label.TextXAlignment = Enum.TextXAlignment.Left
	text_label.Parent = frame
	
	local count = 0
	local go_size = frame.AbsoluteSize.Y

	if #obj:GetChildren() > 0 then
		local arrow = Instance.new("TextButton")
		arrow.Text = ">"
		arrow.TextScaled = true
		arrow.TextWrapped = true
		arrow.BackgroundTransparency = 1
		arrow.TextColor3 = Color3.fromRGB(255, 255, 255)
		arrow.Size = UDim2.new(.1,0,1,0)
		arrow.Parent = frame
		arrow.Activated:Connect(function()
			play_click_button()
			arrow.Text = if arrow.Text == ">" then "v" else ">"
			
			print(go_size, count, count*go_size)
			
			for _,v in pairs(child_frame:GetChildren()) do
				if not v:IsA("Frame") then continue end
				
				v.Size = UDim2.new(1,0,1/count,0)
			end
			
			if not child_frame then return end
			if arrow.Text == ">" then
				child_frame.Size = UDim2.new(1,0,0,0)
				child_frame.Visible = false
			else
				child_frame.Size = UDim2.new(1,0,0,count*go_size)
				child_frame.Visible = true
			end
		end)
	end
	
	if #obj:GetChildren() > 0 then
		child_frame = Instance.new("Frame")
		child_frame.Name = obj.Name.."Child"
		child_frame.LayoutOrder = obj_index +.5
		child_frame.Visible = false
		child_frame.BackgroundTransparency = 1
		child_frame.Size = UDim2.new(1,0,0,0)
		child_frame.Position = UDim2.new(.1,0,1,0)
		child_frame.ClipsDescendants = true
		child_frame.Parent = parent
		
		local list = Instance.new("UIListLayout")
		list.Padding = UDim.new(0,0)
		list.FillDirection = "Vertical"
		list.SortOrder = "LayoutOrder"
		list.HorizontalAlignment = Enum.HorizontalAlignment.Left
		list.VerticalAlignment = Enum.VerticalAlignment.Top
		list.Parent = child_frame
		
		for i, v in pairs(obj:GetChildren()) do
			count += 1
			create_dex_instance(child_frame, v, i)
		end
	end

	local image_instance = Instance.new("ImageLabel")
	image_instance.Image = "rbxasset://textures/ClassImages.png"
	image_instance.ImageRectOffset = Vector2.new(index * icon_size, 0)
	image_instance.ResampleMode = Enum.ResamplerMode.Pixelated
	image_instance.ScaleType = Enum.ScaleType.Fit
	image_instance.BackgroundTransparency = 1
	image_instance.Size = UDim2.new(.1,0,1,0)
	image_instance.Position = UDim2.new(.1,0,0,0)
	image_instance.ImageRectSize = Vector2.new(icon_size, icon_size)
	image_instance.Parent = frame
end

